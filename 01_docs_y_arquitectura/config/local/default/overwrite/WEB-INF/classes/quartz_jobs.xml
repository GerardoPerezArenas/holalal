    <job>
        <job-detail>
            <name>GestionTramitacionAutomaticaKONTUJob</name>
            <group>GestionTramitacionAutomaticaKONTUGroup</group>
            <description>Inicio y gestion automatica de expedientes KONTU</description>
            <job-class>es.altia.flexia.integracion.moduloexterno.melanbide43.job.GestionAutomaticaKONTU</job-class>
            <job-data-map allows-transient-data="false">
                <entry>
                    <key>jndis_lanzamiento_proceso</key>
                    <value>jdbc_flexia_pruebas</value>
                </entry>
            </job-data-map>
        </job-detail>
        <trigger>
            <cron>
                <name>GestionTramitacionAutomaticaKONTUTrigger</name>
                <group>GestionTramitacionAutomaticaKONTUGroup</group>
                <job-name>GestionTramitacionAutomaticaKONTUJob</job-name>
                <job-group>GestionTramitacionAutomaticaKONTUGroup</job-group>
                 <!-- Cada 4 minutos -->
                <cron-expression>0 0/4 * * * ?</cron-expression>
            </cron>
        </trigger>
    </job>

