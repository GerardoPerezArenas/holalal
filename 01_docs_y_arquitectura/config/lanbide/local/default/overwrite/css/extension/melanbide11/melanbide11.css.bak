/* Datos histˇricos (solo consulta) */
.datosAntiguos { background:#f7f7f7; color:#666; font-style: italic; }
th.datosAntiguos { font-weight: normal; }
/* Estilo para datos antiguos */
.datosAntiguos {
  color: #888;
  background-color: #f5f5f5;
  font-style: italic;
}
.legendAzul{
    font-family: Verdana, Arial, Helvetica, sans-serif;
    font-size: 14px;
    color: rgb(43, 98, 181);
    font-weight: bold;
    text-align: center;
}

table.dataTable td {
    padding: 3px 10px;
    width: 1px;
    white-space: nowrap;
}

/* Estilo para los campos antiguos de titulaciˇn en la tabla */
.datoAntiguos {
    background-color: #f0f0f0;
    font-style: italic;
}

/* === DEM50 - Contrataciones: marcar columnas histˇricas === */
th.col-historico {
  background-color: #e6f2ff;   /* azul clarito en cabecera */
}

td.col-historico {
  background-color: #f7fbff;   /* leve realce en celdas */
}

.legend-historico {
  font-size: 11px;
  margin: 4px 0 8px 0;
}

.legend-historico .chip {
  display: inline-block;
  padding: 2px 6px;
  border-radius: 3px;
  background-color: #e6f2ff;
  border: 1px solid #cfe6ff;
  margin-right: 6px;
}

/* === DEM50 - Desglose RSB: alineaciˇn de etiquetas e inputs === */
.lineaFormulario { clear: both; }
.lineaFormulario:after { content: ""; display: block; clear: both; }
.lineaFormulario .etiquetaLPEEL { float:left; width:300px; line-height:22px; }
.lineaFormulario .campoFormulario { float:left; }


/*estilo de la imagen que sale cuando se esta esperando la recarga de una pagina*/
div#barraProgresoLPEEL {
    position: fixed;
    top:0px;
    left:0px;
    width:100%;
    height:100%;
    z-index:9999;
    background-color: rgba(0, 0, 0, .25);
    overflow:hidden;
}

.contenedorHidepage{
    width:275px;
    height:254px;
    margin-top:20%;
    margin-left:35%;
    background-color: rgba(230, 230, 230, 1);
    color: #004595;
    display: block;
    overflow:hidden;
}

.textoHide{
    text-align:center;
    margin: 50px 20px 40px 20px;
    font-size: 16px;
}

.imagenHide{
    width:100%;
    height:60%;
    font-size: 56px;
    color: #004595;
    text-align:center;
    vertical-align:middle;
}

#disco {
    font-size: 56px !important;
}
