0/MODULO_INTEGRACION/MELANBIDE61/REPLE/PLANTILLA_NORMAL/REPLE_ETIQUETA_LISTAREQ/SQL_ETIQUETA=SELECT   RTRIM (XMLAGG (XMLELEMENT (E,REPLACE (DES,'#FECINICONTRELEV#',TO_CHAR (FECHA,   'dd/MM/yyyy'))   || CHR(13))).EXTRACT ('//text()').GETCLOBVAL(),',') AS REQUISITOS FROM   (     SELECT       DESCRIPCION            AS DES,       REPLE_PEXCO2.PEXCO_FAC AS FECHA,       TDET_NUM AS EXPEDIENTE     FROM       E_TDET     INNER JOIN PLANTILLA_DESCLARGA     ON       CODIGO   = TDET_COD     AND IDIOMA ='es'     LEFT JOIN REPLE_PEXCO REPLE_PEXCO1     ON       REPLE_PEXCO1.PEXCO_NUM   =TDET_NUM     AND REPLE_PEXCO1.PEXCO_CTPE=1     LEFT JOIN REPLE_PEXCO REPLE_PEXCO2     ON       REPLE_PEXCO2.PEXCO_NUM   =TDET_NUM     AND REPLE_PEXCO2.PEXCO_CTPE=2     LEFT JOIN       (         SELECT           MAX(REPLE_PEXCO.PEXCO_NCON)AS FILA,           REPLE_PEXCO.PEXCO_NUM         FROM           REPLE_PEXCO         GROUP BY           REPLE_PEXCO.PEXCO_NUM       )       A     ON       A.PEXCO_NUM               =REPLE_PEXCO2.PEXCO_NUM     AND REPLE_PEXCO2.PEXCO_NCON =A.FILA     WHERE     TDET_TRA  =12     AND TDET_VALOR='X'     ORDER BY       codigo   )
