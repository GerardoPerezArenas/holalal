<%@taglib uri="/WEB-INF/struts-logic.tld" prefix="logic" %>
<%@taglib uri="/WEB-INF/struts-bean.tld" prefix="bean" %>
<%@taglib uri="/WEB-INF/tlds/c.tld" prefix="c" %>
<%@page contentType="text/html" pageEncoding="UTF-8"%>
<%@page import="es.altia.flexia.integracion.moduloexterno.melanbide11.i18n.MeLanbide11I18n"%>
<%@page import="es.altia.agora.business.escritorio.UsuarioValueObject"%>
<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="X-UA-Compatible" content="IE=Edge" />
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
  <title>Desglose Retribuci&oacute;n salarial bruta</title>
  <%
    UsuarioValueObject usuarioVO = new UsuarioValueObject();
    int idiomaUsuario = 1, apl = 5;
    String css = "";
    if (session.getAttribute("usuario") != null){
      usuarioVO = (UsuarioValueObject) session.getAttribute("usuario");
      apl = usuarioVO.getAppCod();
      idiomaUsuario = usuarioVO.getIdioma();
      css = usuarioVO.getCss();
    }
    MeLanbide11I18n meLanbide11I18n = MeLanbide11I18n.getInstance();

    String numExpediente = (String)request.getAttribute("numExp");
    String idProyecto    = (String)request.getAttribute("idProyecto");

    String urlPestanaResumen      = (String)request.getAttribute("urlPestanaResumen");
    if (urlPestanaResumen == null || urlPestanaResumen.length()==0) {
      urlPestanaResumen = "/jsp/extension/melanbide11/desglose/m11Desglose_Tab1.jsp";
    }
    String urlPestanaComplementos = (String)request.getAttribute("urlPestanaComplementos");
    if (urlPestanaComplementos == null || urlPestanaComplementos.length()==0) {
      urlPestanaComplementos = "/jsp/extension/melanbide11/desglose/m11Desglose_Tab2.jsp";
    }
  %>
  <link rel="StyleSheet" media="screen" type="text/css" href="<%=request.getContextPath()%><%=css%>"/>
  <link rel="StyleSheet" media="screen" type="text/css" href="<%=request.getContextPath()%>/css/extension/melanbide11/melanbide11.css"/>
  <script type="text/javascript" src="<%=request.getContextPath()%>/scripts/jquery/jquery-1.9.1.min.js"></script>
  <script type="text/javascript" src="<%=request.getContextPath()%>/scripts/JavaScriptUtil.js"></script>
  <script type="text/javascript" src="<%=request.getContextPath()%>/scripts/general.js"></script>
  <script type="text/javascript" src="<%=request.getContextPath()%>/scripts/tabpane.js"></script>
  <script type="text/javascript" src="<%=request.getContextPath()%>/scripts/extension/melanbide11/FixedColumnsTable.js"></script>
  <script type="text/javascript">
    function ajustarVentanaDesglose(){
      try{
        var alto = document.body.scrollHeight + 20;
        var ancho = 860; // acorde al contenedor 820 + margen
        if (window.resizeTo){ window.resizeTo(ancho, (alto<600?600:alto)); }
      }catch(e){}
    }
  </script>
</head>
<body class="bandaBody" onload="elementoVisible('off','barraProgresoLPEEL'); ajustarVentanaDesglose();">
  <div class="tab-page" id="tabPageM11" style="width:820px; margin:10px auto 12px auto;">
    <!-- mĒnimos -->
    <input type="hidden" id="idProyecto"    value="<%=idProyecto%>"/>
    <input type="hidden" id="numExpediente" value="<%=numExpediente%>"/>

   
    <div style="border:1px solid #2f5b8a;background:#2f5b8a;color:#fff;padding:12px 18px;margin:14px 5px 16px 5px;">
  <h1 id="tituloPrincipalM11" style="margin:0;font-size:20px;text-align:center;line-height:1.2;">Retribuci&oacute;n salarial bruta</h1>
      <div style="text-align:center;font-size:13px;margin-top:4px;">
        <strong>Expediente:</strong> <%= (numExpediente!=null?numExpediente:"-") %>
      </div>
    </div>

    <div id="tab-panel-m11" class="tab-pane" align="left"></div>
    <script type="text/javascript">
      var tpM11 = new WebFXTabPane(document.getElementById("tab-panel-m11"));
      tpM11.selectedIndex = 0;
    </script>

    <div class="tab-page" id="tabPageM11_1" style="width:100%; font-size: 13px;">
  <h2 class="tab" id="pestanaM11_1">Retribuci&oacute;n salarial bruta</h2>
      <script type="text/javascript">tpM11.addTabPage(document.getElementById("tabPageM11_1"));</script>
      <div style="clear: both; border:1px solid gray; height:100%; width:98%;">
        <jsp:include page="<%= urlPestanaResumen %>" flush="true"/>
      </div>
    </div>

    <div class="tab-page" id="tabPageM11_2" style="width:100%; font-size: 13px;">
  <h2 class="tab" id="pestanaM11_2">Desglose Retribuci&oacute;n salarial bruta</h2>
      <script type="text/javascript">tpM11.addTabPage(document.getElementById("tabPageM11_2"));</script>
      <div style="clear: both; border:1px solid gray; height:100%; width:98%;">
        <jsp:include page="<%= urlPestanaComplementos %>" flush="true"/>
      </div>
    </div>

    <!-- Botonera global fuera de las pesta±as -->
  <div style="clear:both; text-align:center; margin:12px 0 4px 0; padding:8px 0 4px 0;">
      <input type="button" id="btnAceptarGlobal" name="btnAceptarGlobal" class="botonGeneral" value="<%=meLanbide11I18n.getMensaje(idiomaUsuario, "btn.aceptar")%>" onclick="guardarDesglose();" />
      <input type="button" id="btnCancelarGlobal" name="btnCancelarGlobal" class="botonGeneral" value="<%=meLanbide11I18n.getMensaje(idiomaUsuario, "btn.cancelar")%>" onclick="cancelar();" />
    </div>
  </div>
  <script type="text/javascript">
    (function(){
      function actualizarTitulo(){
        try{
          var h1 = document.getElementById('tituloPrincipalM11');
          if(!h1) return;
          // Buscar pesta±a activa por clase 'selected'
            var tabs = document.querySelectorAll('#tab-panel-m11 .tab-page');
            var activaId = null;
            for(var i=0;i<tabs.length;i++){
              if(/selected/i.test(tabs[i].className)){ activaId = tabs[i].id; break; }
            }
            if(!activaId){
              // fallback: si tpM11.selectedIndex existe
              if (typeof tpM11 !== 'undefined' && tpM11.selectedIndex==1){ activaId='tabPageM11_2'; }
            }
            if (activaId === 'tabPageM11_2'){
              h1.innerHTML = 'Desglose Retribuci&oacute;n salarial bruta';
            } else {
              h1.innerHTML = 'Retribuci&oacute;n salarial bruta';
            }
        }catch(e){/*no-op*/}
      }
      // Hook sobre clicks en tabs
      document.addEventListener('click', function(ev){
        if(ev.target && ev.target.className && /tab/i.test(ev.target.className)){
          setTimeout(actualizarTitulo, 30);
        }
      }, true);
      // Al cargar
      actualizarTitulo();
    })();
  </script>
</body>
</html>
