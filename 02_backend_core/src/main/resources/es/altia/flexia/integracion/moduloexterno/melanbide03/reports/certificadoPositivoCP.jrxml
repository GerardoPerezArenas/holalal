				<textElement textAlignment="Justified" markup="styled">
					<font size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>Honekin batera doakizu Lanbideri eskatutako <style isBold='true' pdfFontName='Helvetica-Bold'>Profesionaltasun Ziurtagiriaren ALDEKO BALORAZIOA</style>, Enplegurako Prestakuntzako eta Diru Sarreren Bermerako Zuzendariak sinatuta.</style> "]]></textFieldExpression>
