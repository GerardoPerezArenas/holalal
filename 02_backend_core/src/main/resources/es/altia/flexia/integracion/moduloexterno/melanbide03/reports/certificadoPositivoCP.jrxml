				<textElement textAlignment="Justified" markup="styled"/>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>"+$P{INTERESADO_SOLICITANTE}+" jaun/andreari (NAN/AIZ "+$P{INTERESADO_DocSOLICITANTE}+") Profesionaltasun-ziurtagiria egiaztatu egin zaio.</style> "]]></textFieldExpression>
			</textField>
