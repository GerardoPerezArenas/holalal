					<font fontName="SansSerif" size="11" isBold="false" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>Le remito adjunta la <style isBold='true' pdfFontName='Helvetica-Bold'>VALORACIÓN POSITIVA del Certificado de Profesionalidad</style> solicitado a Lanbide, firmada por el Director de Formación para el Empleo y Garantía de Ingresos.</style>"]]></textFieldExpression>
