				<textElement textAlignment="Justified" markup="styled"/>
				<text><![CDATA[<style pdfFontName='Helvetica' size ='11'><style isBold='true' pdfFontName='Helvetica-Bold'>JUAN IBARRETXE KARETXE </style>jaunak, Lanbide-Euskal Enplegu Zerbitzuko Enplegurako Prestakuntzako eta Diru Sarreren Bermerako zuzendariak,</style>]]></text>
			</staticText>
			<staticText>
				<reportElement x="40" y="285" width="240" height="20" uuid="140b449e-bbfe-40c4-9d17-29f036049fcb"/>
				<textElement markup="styled"/>
				<text><![CDATA[<style pdfFontName='Helvetica' size ='11'>Profesionaltasun-ziurtagiriaren izena:</style>]]></text>
			</staticText>
			<textField>
				<reportElement key="" x="303" y="149" width="240" height="70" uuid="3cadf44d-aa3f-4737-a3ef-0238acfb71bc"/>
				<textElement textAlignment="Justified" markup="styled">
					<font size="11"/>
				</textElement>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'><style isBold='true' pdfFontName='Helvetica-Bold'>JUAN IBARRETXE KARETXE </style>, Director de Formación para el Empleo y Garantía de Ingresos de Lanbide-Servicio Vasco de Empleo,</style> "]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="303" y="239" width="240" height="66" uuid="6db9d687-86fa-468d-8886-544364258a76"/>
				<textElement textAlignment="Justified" markup="styled">
					<font fontName="SansSerif" size="11" isBold="false" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>Que a D.Dª/ "+$P{INTERESADO_SOLICITANTE}+" con DNI/NIE "+$P{INTERESADO_DocSOLICITANTE}+", se le ha acreditado el Certificado de Profesionalidad de: </style>"]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="302" y="360" width="240" height="80" uuid="aa18621c-1256-48aa-ad89-d62159b9d1b0"/>
				<textElement textAlignment="Justified" markup="styled">
					<font fontName="SansSerif" size="11" isBold="false" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>regulado en el Real Decreto  "+$P{DECRETO}+" de "+$P{FECHARD}+", estando en tramitación la expedición del correspondiente Certificado de Profesionalidad.</style> "]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="40" y="363" width="240" height="77" uuid="9bb6c601-d29e-4d98-87ac-1b08b9d0e4f3"/>
				<textElement textAlignment="Justified" markup="styled"/>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>Zeina "+$P{RDFECHAEUSK}+"ko "+$P{DECRETO}+" Errege Dekretuak arautzen baitu. Jakitera ematen da dagokion Profesionaltasun-ziurtagiria izapidetzen ari dela.</style> "]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="303" y="440" width="240" height="47" uuid="2f243138-aefb-447a-ba12-03499f996e0d"/>
				<textElement textAlignment="Justified" markup="styled">
					<font fontName="SansSerif" size="11" isBold="false" isPdfEmbedded="true"/>
				</textElement>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>Y para que conste y surta los efectos oportunos se expide la presente certificación en </style> "]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement x="40" y="440" width="240" height="47" uuid="52297603-bcef-4a7f-a456-32210998e867"/>
				<textElement textAlignment="Justified" markup="styled"/>
				<textFieldExpression><![CDATA["<style pdfFontName='Helvetica' size ='11'>Eta horrela jasota gera dadin eta dagozkion ondorioak izan ditzan, egiaztagiri hau ematen da.</style> "]]></textFieldExpression>
			</textField>
