<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="altaCentrosAyori_main" pageWidth="620" pageHeight="842" columnWidth="580" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="logo" class="java.io.InputStream"/>
	<parameter name="logo2" class="java.io.InputStream"/>
	<field name="subreport" class="net.sf.jasperreports.engine.JasperReport"/>
	<field name="datasource" class="java.util.List"/>
	<field name="subreportParams" class="java.util.Map"/>
	<group name="group" isStartNewPage="true" minHeightToStartNewPage="700">
		<groupExpression><![CDATA[$V{REPORT_COUNT}]]></groupExpression>
	</group>
	<background>
		<band splitType="Stretch"/>
	</background>
	<title>
		<band splitType="Stretch"/>
	</title>
	<pageHeader>
		<band height="79" splitType="Stretch">
			<image hAlign="Center" vAlign="Middle" isUsingCache="true">
				<reportElement x="0" y="0" width="138" height="62"/>
				<imageExpression><![CDATA[$P{logo}]]></imageExpression>
			</image>
			<image hAlign="Center" vAlign="Middle" isUsingCache="true">
				<reportElement x="418" y="0" width="138" height="62"/>
				<imageExpression><![CDATA[$P{logo2}]]></imageExpression>
			</image>
		</band>
	</pageHeader>
	<columnHeader>
		<band splitType="Stretch"/>
	</columnHeader>
	<detail>
		<band height="8" splitType="Stretch">
			<subreport isUsingCache="false">
				<reportElement x="1" y="0" width="555" height="4"/>
				<parametersMapExpression><![CDATA[$F{subreportParams}]]></parametersMapExpression>
				<dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($F{datasource})]]></dataSourceExpression>
				<subreportExpression><![CDATA[$F{subreport}]]></subreportExpression>
			</subreport>
		</band>
	</detail>
	<columnFooter>
		<band splitType="Stretch"/>
	</columnFooter>
	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>
	<summary>
		<band splitType="Stretch"/>
	</summary>
</jasperReport>
