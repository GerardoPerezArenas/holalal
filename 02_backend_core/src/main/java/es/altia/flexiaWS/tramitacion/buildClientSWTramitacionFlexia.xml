<?xml version="1.0" encoding="ISO-8859-1"?>

<project name="servicioWebTramitacionFlexia" default="init" basedir=".">

    <!-- Para ejecutar desde proyecto\sge\sge\src\java\es\altia\agora\webservice\tramitacion\servicios\tvg -->

    <!-- ======================   Propiedades comunes   ========================== -->
    <!-- Tomcat -->
    <property name="tomcat.home" value="C:/Program Files/Apache Software/apache-tomcat-9.0.40"/>
    <property name="tomcat.libs" value="${tomcat.home}/lib"/>

    <!-- Opciones del entorno de desarrollo  -->
    <property name="build.compiler" value="modern"/>

    <property name="javac.debug" value="on"/>
    <property name="javac.optimize" value="off"/>
    <property name="javac.deprecation" value="on"/>
    <property name="javac.nowarn" value="on"/>
    <patternset id="ignored.files">
        <exclude name="**/SVN/**"/>
        <exclude name="**/*.bak"/>
    </patternset>

    <!-- ============================  Properties ============================== -->
    <property name="project.home" value="C:/Proyectos/Lanbide/flexia19-git"/>
    <property name="project.deploy" value="${project.home}/target/flexia19"/>
    <property name="projectBuildPath" value="${project.deploy}/WEB-INF"/>

    <property name="ext.libs" value="${projectBuildPath}\lib"/>
    <property name="clases" value="${projectBuildPath}\classes\es\altia"/>

    <property name="projectSrcPath" value="${project.home}\src\main\java"/>

    <property name="fuentes" value="${projectSrcPath}\es\altia\flexiaWS\tramitacion"/>
    <property name="fuentesGeneradasCliente" value="${fuentes}\cliente"/>
    <property name="clasesCliente" value="${clases}\flexiaWS\tramitacion\cliente"/>
    <property name="jarCliente" value="C:/Proyectos/Lanbide/WebServicesClientes/WSTramitacionFlexiaClient-19.00.02.jar"/>

    <property name="wsdl" value="${projectSrcPath}\es\altia\flexiaWS\tramitacion\WSTramitacionFlexiaImpl.wsdl"/>

    <!-- == Classpath ==================================================== -->
    <path id="classpath">
        <fileset dir="${ext.libs}">
            <include name="*.jar"/>
        </fileset>
        <fileset dir="${tomcat.libs}">
            <include name="*.jar"/>
        </fileset>
    </path>

    <!-- ========================== "axis" target =========================== -->
    <taskdef name="java2wsdl" classname="org.apache.axis.tools.ant.wsdl.Java2WsdlAntTask" classpathref="classpath"/>
    <taskdef name="wsdl2java" classname="org.apache.axis.tools.ant.wsdl.Wsdl2javaAntTask" classpathref="classpath"/>
    <taskdef name="wsadmin"   classname="org.apache.axis.tools.ant.axis.AdminClientTask" classpathref="classpath"/>

    <!-- == objetivo "init" ==================================================== -->
    <target name="init">
        <echo>
            --------------------------------------------------------------------------------
            "Servicio Web TramitacionFlexia" build ...
            --------------------------------------------------------------------------------
        </echo>
    </target>

    <!-- ==  ========== -->
    <target name="cleanClient" depends="init">
        <delete dir="${clasesCliente}"/>
        <delete dir="${fuentesGeneradasCliente}"/>
    </target>

    <!-- == generar los fuentes del cliente para comunicarse con el servicio web ========== -->
    <target name="wsdl2JavaClient">
        <mkdir dir="${fuentesGeneradasCliente}"/>
        <wsdl2java all="true" debug="false" helperGen="false"
                   noimports="false"
                   output="${fuentesGeneradasCliente}"
                   serverside="true" testcase="false"
                   typeMappingVersion="1.1"
                   url="${wsdl}"
                   verbose="true" noWrapped="true">
            <mapping namespace="http://datos.bd.tramitacion.flexiaWS.altia.es"
                     package="es.altia.flexia.sw.tramitacionFlexia.cliente.datos" />
            <mapping namespace="http://datos.bd.tramitacion.flexiaWS.altia.es-impl"
                     package="es.altia.flexia.sw.tramitacionFlexia.cliente.datos" />
            <mapping namespace="http://datos.bd.tramitacion.flexiaWS.altia.es-intf"
                     package="es.altia.flexia.sw.tramitacionFlexia.cliente.datos" />
            <mapping namespace="http://servicios.flexia"
                     package="es.altia.flexia.sw.tramitacionFlexia.cliente.servicio" />
        </wsdl2java>
    </target>

    <!-- == objetivo "compileClient" ============================================ -->
    <target name="compileClient" depends="init, wsdl2JavaClient">
        <mkdir dir="${clasesCliente}"/>
        <javac srcdir="${fuentesGeneradasCliente}"
               destdir="${clasesCliente}"
               classpathref="classpath"
               debug="${javac.debug}"
               target="1.8"
               source="1.8"
               optimize="${javac.optimize}"
               deprecation="${javac.deprecation}"
               nowarn="${javac.nowarn}"/>
    </target>


    <!-- == objetivo "jarClient"============================================ -->
    <target name="jarClient" depends="init, compileClient">
        <jar destfile="${jarCliente}"
             basedir="${clasesCliente}"/>
    </target>

</project>