    <job>
        <job-detail>
            <name>NotificacionPlazosTramitesJob</name>
            <group>SIGPNotificacionGroup</group>
            <description>Notificacion a tramites</description>
            <job-class>es.altia.agora.interfaces.user.web.sge.notificacion.job.NotificacionPlazoJob</job-class>
            <job-data-map allows-transient-data="false">
                <entry>
                    <key>jndis_lanzamiento_proceso</key>
                    <value>sge_prueba_jndi</value>
                </entry>
            </job-data-map>
        </job-detail>
        <trigger>
            <cron>
                <name>QuartzExampleTrigger</name>
                <group>SIGPNotificacionTriggerGroup</group>
                <job-name>NotificacionPlazosTramitesJob</job-name>
                <job-group>SIGPNotificacionGroup</job-group>
                 <!-- A las 12 de cada dia -->
                <cron-expression>0 0 0 * * ?</cron-expression>
            </cron>
        </trigger>
    </job>
    
    
	<job>
        <job-detail>
            <name>33</name>
            <group>G33</group>
            <description>Notificacion de anotaciones sin adjunto</description>
            <job-class>es.altia.flexia.integracion.moduloexterno.pluginnotificacionplatea.PluginNotificacionJob</job-class>
            <job-data-map allows-transient-data="false">
                <entry>
                    <key>33</key>
                    <value>33</value>                    
                </entry>
            </job-data-map>
        </job-detail>
        <trigger>
            <cron>
                <name>5MIN</name>
                <group>5MINGROUP</group>
                <job-name>33</job-name>
                <job-group>G33</job-group>

                <cron-expression>0 0/1 * * * ?</cron-expression>

		<!--
		<cron-expression>0 05 17 * * ?</cron-expression>
		-->
            </cron>
        </trigger>
    </job> 
	
