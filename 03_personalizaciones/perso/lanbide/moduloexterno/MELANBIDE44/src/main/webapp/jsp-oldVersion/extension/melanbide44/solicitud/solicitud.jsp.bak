<script type="text/javascript">
    <%
        if(ecaSolicitud != null)
        {
    %>
            document.getElementById('col1SolicH').value = '<%=ecaSolicitud.getInserC1H() != null ? ecaSolicitud.getInserC1H().toString() : ""%>';
            document.getElementById('col1SolicM').value = '<%=ecaSolicitud.getInserC1M() != null ? ecaSolicitud.getInserC1M().toString() : ""%>';
            
            reemplazarPuntosEca(document.getElementById('col1SolicH'));
            reemplazarPuntosEca(document.getElementById('col1SolicM'));
            calcularTotalSolicitud('col1SolicH', 'col1SolicM', 'col1SolicT');
            
            document.getElementById('col2SolicH').value = '<%=ecaSolicitud.getInserC2H() != null ? ecaSolicitud.getInserC2H().toString() : ""%>';
            document.getElementById('col2SolicM').value = '<%=ecaSolicitud.getInserC2M() != null ? ecaSolicitud.getInserC2M().toString() : ""%>';
            reemplazarPuntosEca(document.getElementById('col2SolicH'));
            reemplazarPuntosEca(document.getElementById('col2SolicM'));
            calcularTotalSolicitud('col2SolicH', 'col2SolicM', 'col2SolicT');
            
            document.getElementById('col3SolicH').value = '<%=ecaSolicitud.getInserC3H() != null ? ecaSolicitud.getInserC3H().toString() : ""%>';
            document.getElementById('col3SolicM').value = '<%=ecaSolicitud.getInserC3M() != null ? ecaSolicitud.getInserC3M().toString() : ""%>';
            reemplazarPuntosEca(document.getElementById('col3SolicH'));
            reemplazarPuntosEca(document.getElementById('col3SolicM'));
            calcularTotalSolicitud('col3SolicH', 'col3SolicM', 'col3SolicT');
            
            document.getElementById('col4SolicH').value = '<%=ecaSolicitud.getInserC4H() != null ? ecaSolicitud.getInserC4H().toString() : ""%>';
            document.getElementById('col4SolicM').value = '<%=ecaSolicitud.getInserC4M() != null ? ecaSolicitud.getInserC4M().toString() : ""%>';
            reemplazarPuntosEca(document.getElementById('col4SolicH'));
            reemplazarPuntosEca(document.getElementById('col4SolicM'));
            calcularTotalSolicitud('col4SolicH', 'col4SolicM', 'col4SolicT');
            
            document.getElementById('seg1SolicH').value = '<%=ecaSolicitud.getSegH() != null ? ecaSolicitud.getSegH().toString() : ""%>';
            document.getElementById('seg1SolicM').value = '<%=ecaSolicitud.getSegM() != null ? ecaSolicitud.getSegM().toString() : ""%>';
            
            calcularTotalSolicitud('seg1SolicH', 'seg1SolicM', 'seg1SolicT');
                        
            document.getElementById('nActuacionesSolic').value = '<%=ecaSolicitud.getSegActuaciones() != null ? formateador.format (ecaSolicitud.getSegActuaciones().floatValue()):"" %>';
            
            document.getElementById('prospectoresSolicNum').value = '<%=ecaSolicitud.getProspectoresNum() != null ? ecaSolicitud.getProspectoresNum().toString() : ""%>';            
            document.getElementById('prospectoresSolicSol').value = '<%=ecaSolicitud.getProspectoresImp() != null ? formateador.format (ecaSolicitud.getProspectoresImp().floatValue()):"" %>';
            document.getElementById('preparadoresSolicNum').value = '<%=ecaSolicitud.getPreparadoresNum() != null ? ecaSolicitud.getPreparadoresNum().toString() : ""%>';            
            document.getElementById('preparadoresSolicSol').value = '<%=ecaSolicitud.getPreparadoresImp() != null ? formateador.format (ecaSolicitud.getPreparadoresImp().floatValue()):"" %>';            
            document.getElementById('gastosGeneralesSolic').value = '<%=ecaSolicitud.getGastos() != null ? formateador.format (ecaSolicitud.getGastos().floatValue()):"" %>';
            <%
                if(ecaSolicitud.getOtrasSub() != null && ecaSolicitud.getOtrasSub() == true)
                {
            %>
                document.getElementById('radioOtrasAyudasS').checked = true;
            <%
                }
                else
                {
            %>
                document.getElementById('radioOtrasAyudasN').checked = true;
            <%
                }
            %>
            
            document.getElementById('impOrgPublicos').value = '<%=ecaSolicitud.getSubPub() != null ? formateador.format (ecaSolicitud.getSubPub().floatValue()):"" %>';
            document.getElementById('impOrgPrivados').value = '<%=ecaSolicitud.getSubPriv() != null ? formateador.format (ecaSolicitud.getSubPriv().floatValue()):"" %>';                        
            document.getElementById('totSubSolicitada').value = '<%=ecaSolicitud.getTotalSubvencion() != null ? formateador.format (ecaSolicitud.getTotalSubvencion().floatValue()):"" %>';
            calcularTotalSubvSolicitud('prospectoresSolicSol', 'preparadoresSolicSol', 'gastosGeneralesSolic','totSubSolicitada');            
            document.getElementById('totSubAprobada').value = '<%=ecaSolicitud.getTotalAprobado() != null ? formateador.format (ecaSolicitud.getTotalAprobado().floatValue()):"" %>';
    <%
        }
        else
        {
    %>
            document.getElementById('radioOtrasAyudasN').checked = true;
    <%
        } 
    
       if(datosAnexos != null)
        {
    %>
        document.getElementById('col1AnexH').value = '<%=datosAnexos.getC1H() != null ? datosAnexos.getC1H().floatValue() : ""%>';
        document.getElementById('col1AnexM').value = '<%=datosAnexos.getC1M() != null ? datosAnexos.getC1M().floatValue() : ""%>';
        document.getElementById('col1AnexT').value = '<%=datosAnexos.getC1T() != null ? datosAnexos.getC1T().floatValue() : ""%>';
        reemplazarPuntosEca(document.getElementById('col1AnexH'));
        reemplazarPuntosEca(document.getElementById('col1AnexM'));
        reemplazarPuntosEca(document.getElementById('col1AnexT'));
        
        document.getElementById('col2AnexH').value = '<%=datosAnexos.getC2H() != null ? datosAnexos.getC2H().floatValue() : ""%>';
        document.getElementById('col2AnexM').value = '<%=datosAnexos.getC2M() != null ? datosAnexos.getC2M().floatValue() : ""%>';
        document.getElementById('col2AnexT').value = '<%=datosAnexos.getC2T() != null ? datosAnexos.getC2T().floatValue() : ""%>';
        reemplazarPuntosEca(document.getElementById('col2AnexH'));
        reemplazarPuntosEca(document.getElementById('col2AnexM'));
        reemplazarPuntosEca(document.getElementById('col2AnexT'));
        
        document.getElementById('col3AnexH').value = '<%=datosAnexos.getC3H() != null ? datosAnexos.getC3H().floatValue() : ""%>';
        document.getElementById('col3AnexM').value = '<%=datosAnexos.getC3M() != null ? datosAnexos.getC3M().floatValue() : ""%>';
        document.getElementById('col3AnexT').value = '<%=datosAnexos.getC3T() != null ? datosAnexos.getC3T().floatValue() : ""%>';
        reemplazarPuntosEca(document.getElementById('col3AnexH'));
        reemplazarPuntosEca(document.getElementById('col3AnexM'));
        reemplazarPuntosEca(document.getElementById('col3AnexT'));
        
        document.getElementById('col4AnexH').value = '<%=datosAnexos.getC4H() != null ? datosAnexos.getC4H().floatValue() : ""%>';
        document.getElementById('col4AnexM').value = '<%=datosAnexos.getC4M() != null ? datosAnexos.getC4M().floatValue() : ""%>';
        document.getElementById('col4AnexT').value = '<%=datosAnexos.getC4T() != null ? datosAnexos.getC4T().floatValue() : ""%>';
        reemplazarPuntosEca(document.getElementById('col4AnexH'));
        reemplazarPuntosEca(document.getElementById('col4AnexM'));
        reemplazarPuntosEca(document.getElementById('col4AnexT'));
        
        document.getElementById('nActuacionesAnex').value = '<%=datosAnexos.getSeguimientosAnt() != null ? datosAnexos.getSeguimientosAnt().toPlainString() : ""%>';
        document.getElementById('prospectoresAnexNum').value = '<%=datosAnexos.getNumProspectores() != null ? datosAnexos.getNumProspectores().toPlainString() : ""%>';
        
        document.getElementById('prospectoresAnexSol').value = '<%=datosAnexos.getImporteProspectores() != null ? formateador.format (datosAnexos.getImporteProspectores().floatValue()):"" %>';    
        document.getElementById('preparadoresAnexNum').value = '<%=datosAnexos.getNumPreparadores() != null ? datosAnexos.getNumPreparadores().toPlainString() : ""%>';
        document.getElementById('preparadoresAnexSol').value = '<%=datosAnexos.getImportePreparadores() != null ? formateador.format (datosAnexos.getImportePreparadores().floatValue()):"" %>';            
        //FormatNumber(document.getElementById('preparadoresAnexSol').value,'.',','),8,2,document.getElementById('preparadoresAnexSol').id);
    <%
        } 
    
         if(datosCarga != null)
        {
    %>
        document.getElementById('col1AnexCargaH').value = '<%=datosCarga.getC1H() != null ? datosCarga.getC1H().toPlainString() : ""%>';
        document.getElementById('col1AnexCargaM').value = '<%=datosCarga.getC1M() != null ? datosCarga.getC1M().toPlainString() : ""%>';
        document.getElementById('col1AnexCargaT').value = '<%=datosCarga.getC1T() != null ? datosCarga.getC1T().toPlainString() : ""%>';
                
        document.getElementById('col2AnexCargaH').value = '<%=datosCarga.getC2H() != null ? datosCarga.getC2H().toPlainString() : ""%>';
        document.getElementById('col2AnexCargaM').value = '<%=datosCarga.getC2M() != null ? datosCarga.getC2M().toPlainString() : ""%>';
        document.getElementById('col2AnexCargaT').value = '<%=datosCarga.getC2T() != null ? datosCarga.getC2T().toPlainString() : ""%>';
                
        document.getElementById('col3AnexCargaH').value = '<%=datosCarga.getC3H() != null ? datosCarga.getC3H().toPlainString() : ""%>';
        document.getElementById('col3AnexCargaM').value = '<%=datosCarga.getC3M() != null ? datosCarga.getC3M().toPlainString() : ""%>';
        document.getElementById('col3AnexCargaT').value = '<%=datosCarga.getC3T() != null ? datosCarga.getC3T().toPlainString() : ""%>';
                
        document.getElementById('col4AnexCargaH').value = '<%=datosCarga.getC4H() != null ? datosCarga.getC4H().toPlainString() : ""%>';
        document.getElementById('col4AnexCargaM').value = '<%=datosCarga.getC4M() != null ? datosCarga.getC4M().toPlainString() : ""%>';
        document.getElementById('col4AnexCargaT').value = '<%=datosCarga.getC4T() != null ? datosCarga.getC4T().toPlainString() : ""%>';
        
        reemplazarPuntosEca(document.getElementById('col1AnexCargaH'));
        reemplazarPuntosEca(document.getElementById('col1AnexCargaM'));
        reemplazarPuntosEca(document.getElementById('col1AnexCargaT'));
        reemplazarPuntosEca(document.getElementById('col2AnexCargaH'));
        reemplazarPuntosEca(document.getElementById('col2AnexCargaM'));
        reemplazarPuntosEca(document.getElementById('col2AnexCargaT'));
        reemplazarPuntosEca(document.getElementById('col3AnexCargaH'));
        reemplazarPuntosEca(document.getElementById('col3AnexCargaM'));
        reemplazarPuntosEca(document.getElementById('col3AnexCargaT'));
        reemplazarPuntosEca(document.getElementById('col4AnexCargaH'));
        reemplazarPuntosEca(document.getElementById('col4AnexCargaM'));
        reemplazarPuntosEca(document.getElementById('col4AnexCargaT'));
        
        document.getElementById('nActuacionesAnexCarga').value = '<%=datosCarga.getSeguimientosAnt() != null ? datosCarga.getSeguimientosAnt().toPlainString() : ""%>';
        document.getElementById('prospectoresAnexCargaNum').value = '<%=datosCarga.getNumProspectores() != null ? datosCarga.getNumProspectores().toPlainString() : ""%>';        
        document.getElementById('prospectoresAnexCargaSol').value = '<%=datosCarga.getImporteProspectores() != null ? formateador.format (datosCarga.getImporteProspectores().floatValue()):"" %>';    
        document.getElementById('preparadoresAnexCargaNum').value = '<%=datosCarga.getNumPreparadores() != null ? datosCarga.getNumPreparadores().toPlainString() : ""%>';
        document.getElementById('preparadoresAnexCargaSol').value = '<%=datosCarga.getImportePreparadores() != null ? formateador.format (datosCarga.getImportePreparadores().floatValue()):"" %>';            
        document.getElementById('gastosGeneralesAnexCarga').value = '<%=datosCarga.getGastos() != null ? datosCarga.getGastos().toPlainString() : ""%>';
        document.getElementById('gastosGeneralesAnexCarga').value = '<%=datosCarga.getGastos() != null ? formateador.format (datosCarga.getGastos().floatValue()):"" %>';            
        
    <%
        } 
    %> 
        document.getElementById('prospectoresAnexSol').value='<%=importeProspectores != null ? formateador.format(importeProspectores.floatValue()) : "" %>';
        document.getElementById('preparadoresAnexSol').value='<%=importePreparadores != null ? formateador.format(importePreparadores.floatValue()) : "" %>';
        document.getElementById('preparadoresAnexNum').value = '<%=numPreparadoresSinErrores != null ? numPreparadoresSinErrores.toString() : ""%>';
        document.getElementById('prospectoresAnexNum').value = '<%=numProspectoresSinErrores != null ? numProspectoresSinErrores.toString() : ""%>';
         
        
        <%
            BigDecimal gastosGeneralesAnex2 = null;
            if(importeProspectores != null && importePreparadores != null)
            {
                gastosGeneralesAnex2 = importeProspectores.add(importePreparadores);
            }
            else if(importeProspectores != null)
            {
                gastosGeneralesAnex2 = importeProspectores;
            }
            else if(importePreparadores != null)
            {
                gastosGeneralesAnex2 = importePreparadores;
            }

            if(gastosGeneralesAnex2 != null)
            {
        %>
        
                document.getElementById('gastosGeneralesAnex').value ='<%=formateador.format((gastosGeneralesAnex2.multiply(ecaConfig != null && ecaConfig.getPoGastos() != null ? new BigDecimal(ecaConfig.getPoGastos().toString()) : new BigDecimal("1"))).floatValue()) %>';
         
        <%
            }
        %>
            
            
            var totMaxSub;
        <%
            if(importeProspectores != null)
            {
        %>
                if(!totMaxSub){
                    totMaxSub = 0.0;
                }
                totMaxSub += parseFloat(convertirANumero(document.getElementById('prospectoresAnexSol').value));
        <%
            }
        %>   
        <%
            if(importePreparadores != null)
            {
        %>
                if(!totMaxSub){
                    totMaxSub = 0.0;
                }
                totMaxSub += parseFloat(convertirANumero(document.getElementById('preparadoresAnexSol').value));
        <%
            }
        %>   
        <%
            if(gastosGeneralesAnex2 != null)
            {
        %>
                if(!totMaxSub){
                    totMaxSub = 0.0;
                }
                totMaxSub += parseFloat(convertirANumero(document.getElementById('gastosGeneralesAnex').value));
        <%
            }
        %>   
        <%
            if(ecaSolicitud != null && ecaSolicitud.getSubPub() != null)
            {
        %> 
                if(!totMaxSub){
                    totMaxSub = 0.0;
                }
                totMaxSub -= parseFloat(convertirANumero(document.getElementById('impOrgPublicos').value));
        <%
            }
        %>   
        <%
            if(ecaSolicitud != null && ecaSolicitud.getSubPriv() != null)
            {
        %>
                if(!totMaxSub){
                    totMaxSub = 0.0;
                }
                totMaxSub -= parseFloat(convertirANumero(document.getElementById('impOrgPrivados').value));
        <%
            }
        %>   
            
        if(totMaxSub!=undefined){
            document.getElementById('totMaxSub').value = ''+totMaxSub;
        }
        
        reemplazarPuntosEca(document.getElementById('totMaxSub'));
        
        
                    
                    
        var totSolCarga;
        <%
            if(datosCarga != null && datosCarga.getImporteProspectores() != null)
            {
        %>
                if(!totSolCarga){
                    totSolCarga = 0.0;
                }
                totSolCarga += parseFloat(convertirANumero(document.getElementById('prospectoresAnexCargaSol').value));
        <%
            }
        %>   
        <%
            if(datosCarga != null && datosCarga.getImportePreparadores() != null)
            {
        %>
                if(!totSolCarga){
                    totSolCarga = 0.0;
                }
                totSolCarga += parseFloat(convertirANumero(document.getElementById('preparadoresAnexCargaSol').value));
        <%
            }
        %>   
        <%
            if(datosCarga != null && datosCarga.getGastos() != null)
            {
        %>
                if(!totSolCarga){
                    totSolCarga = 0.0;
                }
                totSolCarga += parseFloat(convertirANumero(document.getElementById('gastosGeneralesAnexCarga').value));
        <%
            }
        %>   
        <%
            if(ecaSolicitud != null && ecaSolicitud.getSubPub() != null)
            {
        %>
                if(!totSolCarga){
                    totSolCarga = 0.0;
                }
                totSolCarga -= parseFloat(convertirANumero(document.getElementById('impOrgPublicos').value));
        <%
            }
        %>   
        <%
            if(ecaSolicitud != null && ecaSolicitud.getSubPriv() != null)
            {
        %>
                if(!totSolCarga){
                    totSolCarga = 0.0;
                }
                totSolCarga -= parseFloat(convertirANumero(document.getElementById('impOrgPrivados').value));
        <%
            }
        %>   
            
            if(totSolCarga!= undefined){
                document.getElementById('totSolCarga').value = ''+totSolCarga;
            }
            
        reemplazarPuntosEca(document.getElementById('totSolCarga'));
   
        cambioRadioOtrosOrganismos();
        ajustarDecimalesImportesSolicitud();
        
        activarModoConsulta();
        
</script>